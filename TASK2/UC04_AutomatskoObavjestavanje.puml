@startuml AutomatskoObavjestavanje
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

title UC04: Automatsko obavještavanje o isteku članarine

' Akteri
actor "Administrator" as Admin
actor "Email servis" as EmailServis
actor "Vrijeme\n(Sistem)" as Vrijeme <<system>>

rectangle "Automatsko obavještavanje o isteku članarine" {
    usecase "Pokretanje periodične\nprovjere" as UC4_1
    usecase "Provjera članarina koje\nističu u 7 dana" as UC4_2
    usecase "Slanje email obavještenja" as UC4_3
    usecase "Konfiguracija parametara\nobavještavanja" as UC4_4
    usecase "Generisanje sadržaja\nemail-a" as UC4_5
    usecase "Evidencija poslanih\nobavještenja" as UC4_6
}

' Veze sistema
Vrijeme --> UC4_1

' Veze administratora
Admin --> UC4_4

' Veze email servisa
UC4_3 --> EmailServis

' Include veze
UC4_1 ..> UC4_2 : <<include>>
UC4_2 ..> UC4_3 : <<include>>\n[za svaku članarinu]
UC4_3 ..> UC4_5 : <<include>>
UC4_3 ..> UC4_6 : <<include>>

note right of UC4_1
  Operacija se izvršava
  jednom dnevno putem
  Background Service u
  ASP.NET Core
end note

note right of UC4_2
  Identifikacija članarina
  koje ističu u narednih
  7 dana
end note

note bottom of UC4_3
  Asinhrono slanje email-a
  bez blokiranja glavne aplikacije
end note

@enduml
