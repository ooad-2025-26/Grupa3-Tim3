@startuml PreporukaPlanaTreninga
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

title UC08: Preporuka plana treninga na osnovu ciljeva člana

' Akteri
actor "Član teretane" as Clan
actor "Trener" as Trener

rectangle "Preporuka plana treninga" {
    usecase "Unos fitness ciljeva" as UC8_1
    usecase "Unos parametara" as UC8_2
    usecase "Generisanje\npersonaliziranog plana" as UC8_3
    usecase "Pregled sedmičnog\nplana" as UC8_4
    usecase "Izbor fitness cilja" as UC8_5
    usecase "Izračun BMI" as UC8_6
    usecase "Određivanje kategorije" as UC8_7
    usecase "Odabir šablona\ntreninga" as UC8_8
    usecase "Filtriranje treninga\npo tipu" as UC8_9
    usecase "Prilagođavanje\nintenziteta" as UC8_10
    usecase "Prilagođavanje plana" as UC8_11
    
    note "Fitness ciljevi:\n- Mršavljenje\n- Jačanje mišića\n- Poboljšanje izdržljivosti" as N1
    
    note "Parametri:\n- Težina\n- Visina\n- Godine" as N2
}

' Veze člana
Clan --> UC8_1
Clan --> UC8_4

' Veze trenera
Trener --> UC8_4
Trener --> UC8_11

' Include veze
UC8_1 ..> UC8_5 : <<include>>
UC8_1 ..> UC8_2 : <<include>>
UC8_1 ..> UC8_3 : <<include>>

UC8_3 ..> UC8_6 : <<include>>
UC8_6 ..> UC8_7 : <<include>>
UC8_7 ..> UC8_8 : <<include>>
UC8_8 ..> UC8_9 : <<include>>
UC8_3 ..> UC8_10 : <<include>>

UC8_5 .. N1
UC8_2 .. N2

note right of UC8_6
  BMI = težina / (visina/100)²
end note

note right of UC8_7
  Kategorije:
  - Pothranjen
  - Normalan
  - Prekomjeran
  - Gojazan
end note

note right of UC8_10
  Intenzitet na osnovu
  historije dolazaka:
  - <10: početnik
  - 10-50: srednji
  - >50: napredni
end note

@enduml
