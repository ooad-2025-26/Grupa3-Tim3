@startuml RezervacijaGrupnihTreninga
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

title UC03: Rezervacija grupnih treninga

' Akteri
actor "Član teretane" as Clan
actor "Trener" as Trener

rectangle "Rezervacija grupnih treninga" {
    usecase "Pregled rasporeda treninga" as UC3_1
    usecase "Rezervacija mjesta\nna treningu" as UC3_2
    usecase "Otkazivanje rezervacije" as UC3_3
    usecase "Provjera aktivne članarine" as UC3_4
    usecase "Provjera kapaciteta\ntreninga" as UC3_5
    usecase "Potvrda rezervacije" as UC3_6
    usecase "Pregled liste rezervacija" as UC3_7
    usecase "Filtriranje treninga\npo tipu" as UC3_8
    usecase "Filtriranje treninga\npo datumu" as UC3_9
    
    note "Otkazivanje moguće\nnajkasnije 2 sata\nprije početka" as N1
}

' Veze člana
Clan --> UC3_1
Clan --> UC3_2
Clan --> UC3_3

' Veze trenera
Trener --> UC3_1
Trener --> UC3_7

' Include veze
UC3_2 ..> UC3_4 : <<include>>
UC3_2 ..> UC3_5 : <<include>>
UC3_2 ..> UC3_1 : <<include>>
UC3_5 ..> UC3_6 : <<include>>\n[ako ima mjesta]

' Extend veze
UC3_1 <.. UC3_8 : <<extend>>
UC3_1 <.. UC3_9 : <<extend>>

UC3_3 .. N1

note right of UC3_4
  Sistem provjerava da li
  član ima aktivnu članarinu
end note

note right of UC3_5
  Provjera da li ima
  slobodnih mjesta na treningu
end note

@enduml
