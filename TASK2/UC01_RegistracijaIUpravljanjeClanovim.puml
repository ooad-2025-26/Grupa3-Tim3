@startuml RegistracijaIUpravljanjeClanovima
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

title UC01: Registracija i upravljanje članovima

' Akteri
actor "Član teretane" as Clan
actor "Administrator" as Admin

rectangle "Registracija i upravljanje članovima" {
    usecase "Registracija novog člana" as UC1_1
    usecase "Pregled profila" as UC1_2
    usecase "Ažuriranje profila" as UC1_3
    usecase "Brisanje člana" as UC1_4
    usecase "Generisanje QR koda" as UC1_5
    usecase "Pregled historije dolazaka" as UC1_6
    usecase "Pregled statusa članarine" as UC1_7
    usecase "Validacija podataka" as UC1_8
    usecase "Unos podataka člana" as UC1_9
}

' Veze člana
Clan --> UC1_2
Clan --> UC1_3
Clan --> UC1_6
Clan --> UC1_7

' Veze administratora
Admin --> UC1_1
Admin --> UC1_2
Admin --> UC1_3
Admin --> UC1_4

' Include veze
UC1_1 ..> UC1_9 : <<include>>
UC1_1 ..> UC1_8 : <<include>>
UC1_1 ..> UC1_5 : <<include>>
UC1_3 ..> UC1_8 : <<include>>

' Extend veze
UC1_2 <.. UC1_6 : <<extend>>
UC1_2 <.. UC1_7 : <<extend>>

note right of UC1_1
  Prilikom registracije sistem
  automatski generira jedinstveni
  QR kod za člana
end note

note right of UC1_8
  Validacija: ime, prezime, email,
  telefon, datum rođenja
end note

@enduml
