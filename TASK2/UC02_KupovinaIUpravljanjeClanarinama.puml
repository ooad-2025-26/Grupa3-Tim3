@startuml KupovinaIUpravljanjeClanarinama
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

title UC02: Kupovina i upravljanje članarinama

' Akteri
actor "Član teretane" as Clan
actor "Administrator" as Admin

rectangle "Kupovina i upravljanje članarinama" {
    usecase "Kupovina članarine" as UC2_1
    usecase "Izbor tipa članarine" as UC2_2
    usecase "Pregled aktivnih članarina" as UC2_3
    usecase "Pregled isteklih članarina" as UC2_4
    usecase "Produženje članarine" as UC2_5
    usecase "Deaktivacija članarine" as UC2_6
    usecase "Konfiguracija cijena članarina" as UC2_7
    usecase "Evidentiranje plaćanja" as UC2_8
    usecase "Izračun datuma isteka" as UC2_9
    
    note "Tipovi članarina:\n- Mjesečna\n- Kvartalna\n- Godišnja" as N1
}

' Veze člana
Clan --> UC2_1
Clan --> UC2_3

' Veze administratora
Admin --> UC2_3
Admin --> UC2_4
Admin --> UC2_5
Admin --> UC2_6
Admin --> UC2_7

' Include veze
UC2_1 ..> UC2_2 : <<include>>
UC2_1 ..> UC2_8 : <<include>>
UC2_1 ..> UC2_9 : <<include>>
UC2_5 ..> UC2_9 : <<include>>

' Extend veze
UC2_3 <.. UC2_4 : <<extend>>\n[prikaz istorije]

UC2_2 .. N1

note right of UC2_9
  Datum isteka se računa na osnovu
  odabranog tipa članarine:
  - Mjesečna: +30 dana
  - Kvartalna: +90 dana
  - Godišnja: +365 dana
end note

@enduml
