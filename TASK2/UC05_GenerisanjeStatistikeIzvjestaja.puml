@startuml GenerisanjeStatistikeIzvjestaja
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

title UC05: Generisanje statistike i izvještaja

' Akteri
actor "Administrator" as Admin

rectangle "Generisanje statistike i izvještaja" {
    usecase "Generisanje izvještaja" as UC5_1
    usecase "Odabir vremenskog\nperioda" as UC5_2
    usecase "Generisanje izvještaja\no prihodima" as UC5_3
    usecase "Generisanje izvještaja\no posjetama" as UC5_4
    usecase "Generisanje izvještaja\no treninzima" as UC5_5
    usecase "Agregacija podataka" as UC5_6
    usecase "Sortiranje podataka" as UC5_7
    usecase "Filtriranje podataka" as UC5_8
    usecase "Tabelarni prikaz\nrezultata" as UC5_9
    usecase "Grafički prikaz\nrezultata" as UC5_10
}

' Veze administratora
Admin --> UC5_1

' Include veze
UC5_1 ..> UC5_2 : <<include>>

' Extend veze
UC5_1 <.. UC5_3 : <<extend>>\n[tip: prihodi]
UC5_1 <.. UC5_4 : <<extend>>\n[tip: posjete]
UC5_1 <.. UC5_5 : <<extend>>\n[tip: treninzi]

UC5_3 ..> UC5_6 : <<include>>
UC5_4 ..> UC5_6 : <<include>>
UC5_5 ..> UC5_6 : <<include>>

UC5_6 ..> UC5_7 : <<include>>
UC5_6 ..> UC5_8 : <<include>>

UC5_1 <.. UC5_9 : <<extend>>
UC5_1 <.. UC5_10 : <<extend>>

note right of UC5_3
  Grupisanje plaćanja po mjesecima,
  suma za svaki mjesec,
  sortiranje po datumu
end note

note right of UC5_4
  Grupisanje dolazaka po danima,
  prosjek dnevnih posjeta,
  sortiranje po broju posjeta
end note

note right of UC5_5
  Grupisanje po treningu,
  izračun popunjenosti,
  top 10 najpopularnijih
end note

@enduml
